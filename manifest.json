{
  "manifest_version": 3,
  "name": "Perplexity 助手",
  "version": "1.0.6",
  "description": "自动验证、会话保活、隐私保护、界面精简，还原纯净的使用体验。",
  "permissions": [
    "debugger",
    "webNavigation",
    "tabs",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.perplexity.ai/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.perplexity.ai/*"
      ],
      "js": [
        "scripts/inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.perplexity.ai/*"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}